{
  "name": "projectspice",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "dev": "react-router dev",
    "deploy:staging": "pnpm build && wrangler deploy --env staging",
    "deploy:prod": "pnpm build && wrangler deploy --env production",
    "preview": "pnpm build && vite preview",
    "typecheck": "pnpm cf-typegen && react-router typegen && tsc -b",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply DB --local",
    "seed": "tsx scripts/seed.ts",
    "postinstall": "pnpm cf-typegen || true"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.2",
    "isbot": "^5.1.31",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router": "^7.9.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.13.5",
    "@cloudflare/workers-types": "^4.0.0",
    "@eslint/js": "^9.0.0",
    "@react-router/dev": "^7.9.2",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.19.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.0",
    "wrangler": "^4.40.0"
  }
}
