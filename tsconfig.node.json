{
  "extends": "./tsconfig.json",
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "eslint.config.js",
    "scripts/**/*",
    "app/lib/export-builder.ts",
    "app/lib/ingredient-parser.ts",
    "app/lib/paprika-binary-parser.ts",
    "app/lib/time-parser.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "types": ["node"],
    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler"
  }
}
